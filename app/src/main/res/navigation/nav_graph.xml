<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.stocktracker.ui.login.LoginFragment"
        android:label="Giriş Yap">
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.stocktracker.ui.login.RegisterFragment"
        android:label="Kayıt Ol">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.stocktracker.ui.dashboard.DashboardFragment"
        android:label="Portföy">
        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/stockDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/stockDetailFragment"
        android:name="com.stocktracker.ui.detail.StockDetailFragment"
        android:label="Hisse Detay">
        <argument
            android:name="ticker"
            app:argType="string" />
        <argument
            android:name="stockId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/alertsFragment"
        android:name="com.stocktracker.ui.alerts.AlertsFragment"
        android:label="Uyarılar" />

    <fragment
        android:id="@+id/transactionsFragment"
        android:name="com.stocktracker.ui.transactions.TransactionsFragment"
        android:label="İşlemler" />

</navigation>
